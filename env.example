# AutoClip Environment Variables
# Copy to .env and fill in your values

# Environment
ENVIRONMENT=production
DEBUG=false
PORT=8000

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/autoclip

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
API_DASHSCOPE_API_KEY=sk-your-key
API_MODEL_NAME=qwen-plus
API_MAX_TOKENS=4096
API_TIMEOUT=30

# Clerk Authentication
CLERK_JWT_ISSUER=https://your-issuer.clerk.accounts.dev
CLERK_JWKS_URL=https://your-issuer.clerk.accounts.dev/.well-known/jwks.json

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CREATOR=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx

# Frontend URL (for Stripe redirects)
FRONTEND_URL=https://your-app.railway.app

# Processing Configuration
PROCESSING_CHUNK_SIZE=5000
PROCESSING_MIN_SCORE_THRESHOLD=0.7
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
PROCESSING_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
